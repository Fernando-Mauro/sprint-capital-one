{
  "name": "matchup",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev frontend",
    "build": "next build frontend",
    "start": "next start frontend",
    "lint": "next lint frontend --max-warnings 0",
    "lint:fix": "next lint frontend --fix",
    "typecheck": "tsc -p frontend/tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate-types": "supabase gen types typescript --local > frontend/src/lib/supabase/types.ts",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db seed",
    "db:reset": "supabase db reset",
    "validate": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.47.0",
    "clsx": "^2.1.1",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/node": "22.0.0",
    "eslint": "9.16.0",
    "eslint-config-next": "15.1.0",
    "@typescript-eslint/parser": "8.18.0",
    "@typescript-eslint/eslint-plugin": "8.18.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-react": "7.37.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-jsx-a11y": "6.10.0",
    "prettier": "3.4.0",
    "jest": "29.7.0",
    "@jest/globals": "29.7.0",
    "ts-jest": "29.2.0",
    "@testing-library/react": "16.1.0",
    "@testing-library/jest-dom": "6.6.0",
    "@testing-library/user-event": "14.5.0",
    "jest-environment-jsdom": "29.7.0",
    "@playwright/test": "1.49.0",
    "tailwindcss": "4.0.0",
    "@tailwindcss/postcss": "4.0.0",
    "postcss": "8.5.0"
  }
}